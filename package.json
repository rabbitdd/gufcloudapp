{
  "name": "gufcloud",
  "version": "1.0.0",
  "description": "MVP web-native music app with Next.js and Supabase",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "infra:up": "supabase start",
    "infra:down": "supabase stop",
    "infra:status": "supabase status",
    "env:local": "supabase status -o env --override-name api.url=NEXT_PUBLIC_SUPABASE_URL --override-name auth.anon_key=NEXT_PUBLIC_SUPABASE_ANON_KEY",
    "env:local:all": "supabase status -o env --override-name api.url=NEXT_PUBLIC_SUPABASE_URL --override-name auth.anon_key=NEXT_PUBLIC_SUPABASE_ANON_KEY --override-name auth.service_role_key=SUPABASE_SERVICE_ROLE_KEY",
    "env:local:pretty": "supabase status",
    "db:reset": "supabase db reset",
    "worker:ingestion": "node scripts/ingestion-worker.mjs",
    "worker:ingestion:once": "WORKER_ONCE=1 node scripts/ingestion-worker.mjs"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.99.2",
    "next": "^16.1.7",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.1.7",
    "postcss": "^8.5.8",
    "supabase": "^2.83.0",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3"
  }
}
