# --- Required (Next.js reads these at runtime) ---
# Use either a hosted Supabase project OR local Supabase (see README).

# Must be the Supabase HTTP API URL (https://…supabase.co or http://127.0.0.1:54321).
# Do NOT paste DB_URL / postgresql://… here — that is only for direct Postgres clients.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Local Supabase (after `npm run infra:up`), paste from `npm run env:local`:
# NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- Optional (not used by current app code) ---
# SUPABASE_SERVICE_ROLE_KEY=
