# --- Required (Next.js reads these at runtime) ---
# Use either a hosted Supabase project OR local Supabase (see README).

# Must be the Supabase HTTP API URL (https://…supabase.co or http://127.0.0.1:54321).
# Do NOT paste DB_URL / postgresql://… here — that is only for direct Postgres clients.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Local Supabase (after `npm run infra:up`), paste from `npm run env:local`:
# NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- Server-side / worker ---
# Recommended for hardened signed URL issuance and required for the ingestion worker.
SUPABASE_SERVICE_ROLE_KEY=

# Optional worker tuning
# WORKER_POLL_INTERVAL_MS=3000

# --- Vercel cron worker mode ---
# For Vercel-only deployments (no persistent worker process), set CRON_SECRET
# and add the same value in Vercel env. Vercel cron calls
# /api/worker/ingestion-tick with Authorization: Bearer <CRON_SECRET>.
# CRON_SECRET=
# INGESTION_TICK_BATCH_SIZE=5
